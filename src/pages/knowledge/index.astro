---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import { Footer } from '../../components/Footer';
import { Button } from '../../components/ui/button';
import { Badge } from '../../components/ui/badge';
import {
  Card,
  CardAction,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
  CardFooter,
} from '../../components/ui/card';

const articles = await getCollection('knowledge');
const categories = [
  {
    key: 'getting-started',
    title: 'Getting Started',
    description: 'Set up your account, learn the daily flow, and get studying fast.',
  },
  {
    key: 'features',
    title: 'Features and Study Tools',
    description: 'Deep dives into SRS stages, reviews, lessons, and study modes.',
  },
  {
    key: 'billing',
    title: 'Billing and Plans',
    description: 'Understand what is included in Free and Pro.',
  },
  {
    key: 'troubleshooting',
    title: 'Troubleshooting',
    description: 'Fix common issues with sync, offline access, and playback.',
  },
];

const articlesByCategory = categories.map((category) => ({
  ...category,
  articles: articles
    .filter((article) => article.data.category === category.key)
    .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
}));

const featureArticles = articlesByCategory.find((category) => category.key === 'features')?.articles ?? [];
const isDev = import.meta.env.DEV;
---

<Layout title="Knowledge Base | Torii SRS">
  <link slot="head" rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script slot="head" src="/pagefind/pagefind-ui.js" defer></script>
  <script
    slot="head"
    is:inline
  >
    window.addEventListener("load", () => {
      if (window.PagefindUI) {
        new window.PagefindUI({
          element: "#pagefind-search",
          showSubResults: true,
          translations: {
            placeholder: "What would you like to know?",
            zero_results: "No matching articles.",
          },
        });
      }
    });
  </script>

  <div class="min-h-screen bg-gradient-to-b from-muted/40 via-background to-background">
    <div data-pagefind-ignore>
      <Navbar client:load />
    </div>

    <div class="w-full">
      <div class="mx-auto max-w-7xl px-6 py-16 sm:px-10 lg:px-12">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
            Torii SRS Knowledge Base
          </h1>
          <p class="mt-4 text-lg text-muted-foreground">
            Everything you need to learn faster with Torii SRS, from daily reviews to
            offline access. Search by topic or browse by category.
          </p>

          <div id="pagefind-search" class="knowledge-search mt-8 text-left backdrop-blur-sm" data-pagefind-ignore></div>
          {isDev && (
            <p class="mt-3 text-sm text-muted-foreground">
              Search indexing is available in build preview. Run <code>pnpm build && pnpm preview</code>.
            </p>
          )}
        </div>
      </div>
    </div>

    <main class="mx-auto max-w-7xl px-6 pb-16 lg:pb-20">
      <section class="mt-16">
        <div class="grid gap-6 lg:grid-cols-2">
          {articlesByCategory.map((category) => (
            <Card className="bg-card/90 shadow-sm">
              <CardHeader className="flex flex-row items-start justify-between gap-4">
                <div>
                  <CardTitle className="text-lg">{category.title}</CardTitle>
                  <CardDescription className="mt-1 text-sm">
                    {category.description}
                  </CardDescription>
                </div>
                <CardAction>
                  <Badge variant="secondary">{category.articles.length} articles</Badge>
                </CardAction>
              </CardHeader>

              <CardFooter className="flex w-full flex-col items-stretch gap-2">
                {category.articles.map((post) => (
                  <Button
                    variant="link"
                    size="lg"
                    className="justify-start rounded-xl text-left text-sm font-semibold transition-colors whitespace-normal"
                  >
                    <a href={`/knowledge/${post.slug}`}>{post.data.title}</a>
                  </Button>
                ))}
              </CardFooter>
            </Card>
          ))}
        </div>
      </section>

      <section class="mt-16">
        <Card className="border-border bg-gradient-to-r from-blue-50 via-white to-blue-50 shadow-sm dark:from-blue-950/40 dark:via-background dark:to-blue-950/40">
          <CardContent className="p-8">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
              <div>
                <h3 class="text-2xl font-semibold">Looking for a specific feature?</h3>
                <p class="mt-2 text-sm text-muted-foreground">
                  Use search or jump into the most requested guides below.
                </p>
              </div>
              <div class="flex flex-wrap gap-2">
                {featureArticles.slice(0, 3).map((post) => (
                  <Button variant="outline" size="sm">
                    <a href={`/knowledge/${post.slug}`}>{post.data.title}</a>
                  </Button>
                ))}
              </div>
            </div>
          </CardContent>
        </Card>
      </section>
    </main>

    <div data-pagefind-ignore>
      <Footer />
    </div>
  </div>
</Layout>
