---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import { Footer } from '../../components/Footer';
import { Button } from '../../components/ui/button';
import { Badge } from '../../components/ui/badge';
import {
  Card,
  CardAction,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
  CardFooter,
} from '../../components/ui/card';

type KnowledgeArticle = CollectionEntry<'knowledge'>;
type KnowledgeCategory = KnowledgeArticle['data']['category'];

interface Category {
  key: KnowledgeCategory;
  title: string;
  description: string;
}

const articles: KnowledgeArticle[] = await getCollection('knowledge');
const categories: Category[] = [
  {
    key: 'getting-started',
    title: 'Getting Started',
    description: 'Set up your account, learn the daily flow, and get studying fast.',
  },
  {
    key: 'features',
    title: 'Features and Study Tools',
    description: 'Deep dives into SRS stages, reviews, lessons, and study modes.',
  },
  {
    key: 'billing',
    title: 'Billing and Plans',
    description: 'Understand what is included in Free and Pro.',
  },
  {
    key: 'troubleshooting',
    title: 'Troubleshooting',
    description: 'Fix common issues with sync, offline access, and playback.',
  },
];

const articlesByCategory = categories.map((category) => ({
  ...category,
  articles: articles
    .filter((article) => article.data.category === category.key)
    .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
}));

const isDev = import.meta.env.DEV;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const messageMinLength = 20;
const messageMaxLength = 1000;
const isTurnstileConfigured = Boolean(turnstileSiteKey);
---

<Layout title="Knowledge Base | Torii SRS">
  <link slot="head" rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script slot="head" src="/pagefind/pagefind-ui.js" defer is:inline></script>
  {turnstileSiteKey && (
    <script
      slot="head"
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
      is:inline
    ></script>
  )}
  <script
    slot="head"
    is:inline
  >
    document.addEventListener("astro:page-load", () => {
      if (window.PagefindUI) {
        new window.PagefindUI({
          element: "#pagefind-search",
          showSubResults: true,
          translations: {
            placeholder: "What would you like to know?",
            zero_results: "No matching articles.",
          },
        });
      }
    });
  </script>
  <script
    slot="head"
    is:inline
  >
    document.addEventListener("astro:page-load", () => {
      const form = document.querySelector("[data-contact-form]");
      if (!(form instanceof HTMLFormElement)) {
        return;
      }

      const status = form.querySelector("[data-contact-status]");
      const submitButton = form.querySelector("[data-contact-submit]");

      /** @param {string} message @param {"success" | "error"} variant */
      const setStatus = (message, variant) => {
        if (!(status instanceof HTMLElement)) {
          return;
        }

        const baseClasses = "text-sm";
        const variantClass = variant === "error" ? "text-destructive" : "text-emerald-700 dark:text-emerald-400";
        status.className = `${baseClasses} ${variantClass}`;
        status.textContent = message;
      };

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!form.reportValidity()) {
          return;
        }

        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
        }

        setStatus("Sending message...", "success");

        try {
          const response = await fetch(form.action, {
            method: "POST",
            body: new FormData(form),
            headers: {
              Accept: "application/json",
            },
          });

          /** @type {{ error?: string } | null} */
          const payload = await response.json().catch(() => null);
          if (!response.ok) {
            const message = payload?.error ?? "Unable to send your message. Please try again.";
            setStatus(message, "error");
            if (window.turnstile?.reset) {
              window.turnstile.reset();
            }
            return;
          }

          form.reset();
          if (window.turnstile?.reset) {
            window.turnstile.reset();
          }
          setStatus("Message sent successfully.", "success");
        } catch (_) {
          setStatus("Unable to send your message. Please try again.", "error");
        } finally {
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
          }
        }
      });
    });
  </script>

  <div class="min-h-screen bg-gradient-to-b from-muted/40 via-background to-background">
    <div data-pagefind-ignore>
      <Navbar client:load />
    </div>

    <div class="w-full">
      <div class="mx-auto max-w-7xl px-6 py-16 sm:px-10 lg:px-12">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
            Torii SRS Knowledge Base
          </h1>
          <p class="mt-4 text-lg text-muted-foreground">
            Everything you need to learn faster with Torii SRS, from daily reviews to
            offline access. Search by topic or browse by category.
          </p>

          <div id="pagefind-search" class="knowledge-search mt-8 text-left backdrop-blur-sm" data-pagefind-ignore></div>
          {isDev && (
            <p class="mt-3 text-sm text-muted-foreground">
              Search indexing is available in build preview. Run <code>pnpm build && pnpm preview</code>.
            </p>
          )}
        </div>
      </div>
    </div>

    <main class="mx-auto max-w-7xl px-6 pb-16 lg:pb-20">
      <section class="mt-16">
        <div class="grid gap-6 lg:grid-cols-2">
          {articlesByCategory.map((category) => (
            <Card className="bg-card/90 shadow-sm">
              <CardHeader className="flex flex-row items-start justify-between gap-4">
                <div>
                  <CardTitle className="text-lg">{category.title}</CardTitle>
                  <CardDescription className="mt-1 text-sm">
                    {category.description}
                  </CardDescription>
                </div>
                <CardAction>
                  <Badge variant="secondary">{category.articles.length} articles</Badge>
                </CardAction>
              </CardHeader>

              <CardFooter className="flex w-full flex-col items-stretch gap-2">
                {category.articles.map((post) => (
                  <Button
                    variant="link"
                    size="lg"
                    className="justify-start rounded-xl text-left text-sm font-semibold transition-colors whitespace-normal"
                  >
                    <a href={`/knowledge/${post.id}`}>{post.data.title}</a>
                  </Button>
                ))}
              </CardFooter>
            </Card>
          ))}
        </div>
      </section>

      <section class="mt-16">
        <Card className="border-border bg-card/90 shadow-sm">
          <CardHeader>
            <CardTitle className="text-2xl">Contact Support</CardTitle>
            <CardDescription>
              Send us a message and we will follow up as soon as possible.
            </CardDescription>
          </CardHeader>
          <CardContent className="p-6 pt-0 sm:p-8 sm:pt-0">
            <form
              class="grid gap-5"
              method="post"
              action="/api/contact"
              data-contact-form
            >
              <div class="grid gap-5 sm:grid-cols-2">
                <div class="grid gap-2">
                  <label class="text-sm font-medium" for="contact-name">Name</label>
                  <input
                    id="contact-name"
                    name="name"
                    type="text"
                    required
                    autocomplete="name"
                    class="h-11 rounded-md border border-input bg-background px-3 py-2 text-sm shadow-xs transition-colors focus-visible:border-ring focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/30"
                  />
                </div>
                <div class="grid gap-2">
                  <label class="text-sm font-medium" for="contact-email">Email</label>
                  <input
                    id="contact-email"
                    name="email"
                    type="email"
                    required
                    autocomplete="email"
                    class="h-11 rounded-md border border-input bg-background px-3 py-2 text-sm shadow-xs transition-colors focus-visible:border-ring focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/30"
                  />
                </div>
              </div>

              <div class="grid gap-2">
                <label class="text-sm font-medium" for="contact-message">Message</label>
                <textarea
                  id="contact-message"
                  name="message"
                  required
                  minlength={messageMinLength}
                  maxlength={messageMaxLength}
                  rows={6}
                  class="rounded-md border border-input bg-background px-3 py-2 text-sm shadow-xs transition-colors focus-visible:border-ring focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/30"
                ></textarea>
                <p class="text-xs text-muted-foreground">
                  Message must be {messageMinLength}-{messageMaxLength} characters.
                </p>
              </div>

              {turnstileSiteKey ? (
                <div
                  class="cf-turnstile"
                  data-sitekey={turnstileSiteKey}
                  data-theme="auto"
                  data-appearance="always"
                  data-action="knowledge_contact"
                ></div>
              ) : (
                <p class="text-xs text-destructive">
                  Turnstile is not configured. Set <code>PUBLIC_TURNSTILE_SITE_KEY</code>.
                </p>
              )}

              <p data-contact-status class="text-sm" role="status" aria-live="polite"></p>

              <div>
                <Button
                  type="submit"
                  className="w-full sm:w-auto"
                  data-contact-submit
                  disabled={!isTurnstileConfigured}
                >
                  Send message
                </Button>
              </div>
            </form>
          </CardContent>
        </Card>
      </section>
    </main>

    <div data-pagefind-ignore>
      <Footer />
    </div>
  </div>
</Layout>
