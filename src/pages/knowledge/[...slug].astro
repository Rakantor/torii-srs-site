---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import { Footer } from '../../components/Footer';

type KnowledgeArticle = CollectionEntry<'knowledge'>;

export async function getStaticPaths() {
  const articles: KnowledgeArticle[] = await getCollection('knowledge');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

interface Props {
  article: KnowledgeArticle;
}

const { article } = Astro.props;
const { Content } = await render(article);

const categoryLabels: Record<string, string> = {
  'getting-started': 'Getting Started',
  features: 'Features and Study Tools',
  billing: 'Billing and Plans',
  troubleshooting: 'Troubleshooting',
};

const allArticles = await getCollection('knowledge');
const related = allArticles
  .filter((item) => item.data.category === article.data.category && item.id !== article.id)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);
---

<Layout title={`${article.data.title} | Torii SRS Knowledge Base`}>
  <div class="min-h-screen bg-gradient-to-b from-muted/30 via-background to-background">
    <div data-pagefind-ignore>
      <Navbar client:load />
    </div>

    <main class="mx-auto max-w-3xl px-6 py-12 lg:py-16">
      <a href="/knowledge" class="text-sm text-muted-foreground transition hover:text-foreground">
        ← Back to Knowledge Base
      </a>

      <header class="mt-6 space-y-4">
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
          {categoryLabels[article.data.category] ?? article.data.category}
        </p>
        <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
          {article.data.title}
        </h1>
        <p class="text-lg text-muted-foreground">{article.data.description}</p>
      </header>

      <article
        class="mt-10 space-y-6 text-base leading-7 text-foreground [&>h2]:mt-10 [&>h2]:text-2xl [&>h2]:font-semibold [&>h3]:mt-8 [&>h3]:text-xl [&>h3]:font-semibold [&>p]:text-muted-foreground [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:text-muted-foreground [&>ul]:space-y-2 [&>ol]:list-decimal [&>ol]:pl-6 [&>ol]:text-muted-foreground [&>ol]:space-y-2 [&_strong]:text-foreground [&_code]:rounded [&_code]:bg-muted [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-sm"
        data-pagefind-body
      >
        <Content />
      </article>

      {related.length > 0 && (
        <section class="mt-12 border-t border-border pt-8">
          <h2 class="text-lg font-semibold">Related articles</h2>
          <div class="mt-4 grid gap-3">
            {related.map((item) => (
              <a
                href={`/knowledge/${item.id}`}
                class="rounded-xl border border-border bg-card/90 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:shadow-sm"
              >
                <p class="font-semibold">{item.data.title}</p>
                <p class="mt-1 text-xs text-muted-foreground">{item.data.description}</p>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>

    <div data-pagefind-ignore>
      <Footer />
    </div>
  </div>
</Layout>
