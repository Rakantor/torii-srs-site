---
import Layout from "../layouts/Layout.astro";
import { Navbar } from "../components/Navbar";
import { Footer } from "../components/Footer";
import { Button } from "../components/ui/button";
import errorImage from "../assets/404.webp";
---

<Layout title="Page Not Found | Torii SRS">
  <div class="min-h-screen bg-gradient-to-b from-muted/30 via-background to-background">
    <Navbar client:load />

    <main class="mx-auto flex min-h-[70vh] max-w-5xl flex-col items-center justify-center px-6 py-16 text-center">
      <img
        src={errorImage.src}
        alt="404 torii gate portal"
        class="mb-8 w-full max-w-md rounded-3xl"
        loading="eager"
      />

      <h1 class="text-3xl font-medium tracking-tight sm:text-4xl">
        This page passed through the gate and never came back.
      </h1>
      <p class="mt-4 text-base text-muted-foreground">
        The path may be broken or the page moved. Head back to the main site and
        we will get you oriented.
      </p>

      <div class="mt-8">
        <Button size="lg">
          <a href="/">Return to safety</a>
        </Button>
      </div>
    </main>

    <Footer />
  </div>
</Layout>
